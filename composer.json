{
    "name": "kryvestudio/github-api",
    "description": "PHP wrapper for GitHub REST API by Kryve Studio",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Kryve\\GithubApi\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "config": {
        "audit": {
            "ignore": ["PKSA-z3gr-8qht-p93v"]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "11.0"
    }
}
